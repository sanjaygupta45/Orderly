# ============================================
#   Java & Spring Boot GitIgnore Template
# ============================================

# --- Compiled class files ---
*.class

# --- Log files ---
*.log
*.out

# --- BlueJ files ---
*.ctxt

# --- Mobile Tools for Java (J2ME) ---
.mtj.tmp/

# --- Package Files ---
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- JVM crash logs ---
hs_err_pid*
replay_pid*

# --- IDEA / Eclipse / VSCode Project Settings ---
*.iml
.idea/
.vscode/
.classpath
.project
.settings/

# --- Maven & Gradle ---
target/
build/
out/
.gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradlew
!gradlew.bat

# --- Local Environment Variables ---
.env
.env.*
!.env.example

# --- Docker ---
# Track compose files, Dockerfiles and config (prometheus/grafana provisioning);
# ignore only the runtime data directories.
docker/mysql/
docker/mongodb/

# --- OS generated files ---
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
__MACOSX/

# --- Temporary files ---
*.swp
*.swo
*.tmp
*.bak
*.backup

# --- Local database / data dump ---
# NOTE: mysql/init.sql is tracked on purpose (needed for one-command startup),
# so we do not blanket-ignore *.sql or the mysql/ directory here.
*.sqlite
*.db
/data/
postgres/

# --- Node (if using frontend in same repo) ---
node_modules/
npm-debug.log
yarn-error.log
.pnpm-store/

# --- Coverage / Testing ---
/coverage/
.test/
reports/
jacoco.exec

# --- Cache & Temp ---
/.cache/
/tmp/
/logs/

# --- OS & Tool specific ---
*.pid
*.seed
*.lock

# --- Others you may want to keep ignored ---
/uploads/
/storage/
/secrets/
/keys/
